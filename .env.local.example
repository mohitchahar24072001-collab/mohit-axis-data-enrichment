# Google Custom Search API
# Get your API key from: https://developers.google.com/custom-search/v1/introduction
GOOGLE_CUSTOM_SEARCH_API_KEY=your_google_api_key_here

# Google Custom Search Engine ID (cx)
# Create a custom search engine at: https://programmablesearchengine.google.com/
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=your_search_engine_id_here

# Anthropic API Key
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: SerpAPI (fallback search provider)
# Get your API key from: https://serpapi.com/
# SERP_API_KEY=your_serpapi_key_here
